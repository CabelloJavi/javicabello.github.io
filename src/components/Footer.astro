---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <ul class="links">
    <li><a href="https://github.com/CabelloJavi" rel="me noopener" target="_blank">GitHub</a></li>
    <li><a href="https://www.linkedin.com/in/javier-cabello-laguna" rel="me noopener" target="_blank">LinkedIn</a></li>
    <li><a href="mailto:info@javicabello.dev">info@javicabello.dev</a></li>
    <li>
      <a href="https://humanos-frame.beehiiv.com/" rel="noopener" target="_blank">
        Human/OS <span aria-hidden="true">&#8599;</span>
      </a>
    </li>
  </ul>
  <p class="meta">
    <span>© {year} Javier Cabello Laguna</span>
    <span aria-hidden="true"> · </span>
    <span>Built with Astro</span>
  </p>
</footer>

<style>
  .site-footer {
    width: 100%;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6) var(--space-8);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-16);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  .links li {
    margin: 0;
  }

  .links a {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--color-fg-muted);
    text-decoration: none;
  }

  .links a:hover {
    color: var(--color-fg);
  }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-fg-subtle);
    margin: 0;
  }
</style>
