---
const internalLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/contact', label: 'Contact' },
];

const HUMANOS_URL = 'https://humanos-frame.beehiiv.com/';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <a href="/" class="wordmark" aria-label="Javi Cabello — Home">
    <span class="wordmark__name mono">Javi Cabello</span>
  </a>

  <nav aria-label="Primary">
    <ul>
      {
        internalLinks.map((link) => {
          const target = link.href.replace(/\/$/, '') || '/';
          const isActive = target === path;
          return (
            <li>
              <a href={link.href} aria-current={isActive ? 'page' : undefined}>
                {link.label}
              </a>
            </li>
          );
        })
      }
      <li class="external">
        <a href={HUMANOS_URL} rel="noopener" target="_blank">
          Human/OS <span aria-hidden="true">&#8599;</span>
        </a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    width: 100%;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .wordmark {
    text-decoration: none;
    color: var(--color-fg);
  }

  .wordmark:hover {
    color: var(--color-fg);
  }

  .wordmark__name {
    font-weight: 600;
    font-size: var(--fs-base);
    letter-spacing: -0.01em;
  }

  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  nav li {
    margin: 0;
  }

  nav a {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--color-fg-muted);
    text-decoration: none;
  }

  nav a:hover,
  nav a[aria-current='page'] {
    color: var(--color-fg);
  }

  .external {
    padding-left: var(--space-4);
    margin-left: var(--space-2);
    border-left: 1px solid var(--color-border);
  }

  .external a {
    color: var(--color-fg);
  }

  .external a:hover {
    color: var(--color-accent);
  }
</style>
