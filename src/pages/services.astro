---
import Base from '../layouts/Base.astro';

const description =
  'Engineering leadership, technical advisory, and hands-on work on identity, agents, and verifiable systems.';
---

<Base title="Services" description={description}>
  <h1>Services</h1>

  <section class="prose">
    <p class="lede">
      Engineering leadership and technical advisory for teams building identity,
      agent systems, and verifiable infrastructure.
    </p>

    <p class="muted soon mono">Coming soon.</p>
  </section>
</Base>

<style>
  .prose {
    max-width: var(--measure);
  }

  .lede {
    font-size: var(--fs-lg);
    color: var(--color-fg-muted);
    margin-bottom: var(--space-12);
  }

  .soon {
    font-size: var(--fs-sm);
  }
</style>
