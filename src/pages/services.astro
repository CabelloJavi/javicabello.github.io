---
import Base from '../layouts/Base.astro';

const description = '{{COPY_SERVICES_META_DESCRIPTION}}';
---

<Base title="Services" description={description}>
  <h1>Services</h1>

  <section class="prose">
    <p class="lede">{`{{COPY_SERVICES_LEDE}}`}</p>

    <p class="muted soon mono">Coming soon.</p>
  </section>
</Base>

<style>
  .prose {
    max-width: var(--measure);
  }

  .lede {
    font-size: var(--fs-lg);
    color: var(--color-fg-muted);
    margin-bottom: var(--space-12);
  }

  .soon {
    font-size: var(--fs-sm);
  }
</style>
